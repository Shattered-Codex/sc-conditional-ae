<section class="tab scrollable {{#if tab.active}}active{{/if}} sc-cae-condition-tab" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">
  <fieldset>
    <legend>{{ strings.heading }}</legend>
    <p class="hint">{{ strings.hint }}</p>
    {{#if strings.compatibilityHint}}
    <p class="hint sc-cae-compatibility-hint">
      <i class="fas fa-wand-magic-sparkles"></i>
      {{ strings.compatibilityHint }}
    </p>
    {{/if}}
    <p class="hint">{{ strings.variables }}</p>
    <a class="sc-cae-help-link" href="{{ conditionWikiUrl }}" target="_blank" rel="noopener">
      <i class="fas fa-up-right-from-square"></i> {{ strings.wiki }}
    </a>

    {{#if conditionInvalid}}
    <p class="notification warning sc-cae-validation-warning">
      <i class="fas fa-triangle-exclamation"></i>
      {{ strings.invalid }} {{ validationMessage }}
    </p>
    {{/if}}

    <div class="sc-cae-evaluation sc-cae-evaluation--{{ evaluation.state }}">
      <div class="sc-cae-evaluation__header">{{ strings.evaluationHeading }}</div>
      <p class="hint sc-cae-evaluation__message">
        {{#if evaluation.isEmpty}}
        {{ strings.evaluationEmpty }}
        {{else}}
          {{#if evaluation.isTrue}}
          {{ strings.evaluationTrue }}
          {{else}}
            {{#if evaluation.isFalse}}
            {{ strings.evaluationFalse }}
            {{else}}
            {{ strings.evaluationError }} {{ evaluation.errorMessage }}
            {{/if}}
          {{/if}}
        {{/if}}
      </p>
      {{#if evaluation.hasResult}}
      <p class="hint sc-cae-evaluation__detail">
        <strong>{{ strings.evaluationResult }}:</strong>
        <code>{{ evaluation.resultLabel }}</code>
      </p>
      {{/if}}
      {{#if evaluation.contextLabel}}
      <p class="hint sc-cae-evaluation__detail">
        <strong>{{ strings.evaluationContext }}:</strong>
        {{ evaluation.contextLabel }}
      </p>
      {{/if}}
      {{#if evaluation.effectStateLabel}}
      <p class="hint sc-cae-evaluation__detail">
        <strong>{{ strings.evaluationEffectState }}:</strong>
        <code>{{ evaluation.effectStateLabel }}</code>
      </p>
      {{/if}}
    </div>

    {{#if editable}}
    <code-mirror
      name="{{ conditionFlagPath }}"
      language="javascript"
      indent="2"
      class="sc-cae-condition-code"
      aria-label="{{ strings.label }}"
    >{{ conditionInputValue }}</code-mirror>
    {{else}}
    <textarea
      name="{{ conditionFlagPath }}"
      class="sc-cae-condition-code sc-cae-condition-code--readonly"
      rows="10"
      placeholder="{{ strings.placeholder }}"
      disabled>{{ conditionInputValue }}</textarea>
    {{/if}}
  </fieldset>
</section>
