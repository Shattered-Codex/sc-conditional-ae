<section class="tab scrollable {{#if tab.active}}active{{/if}} sc-cae-condition-tab" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">
  <fieldset>
    <legend>{{ strings.heading }}</legend>
    {{#if strings.compatibilityHint}}
    <p class="hint sc-cae-compatibility-hint">
      <i class="fas fa-wand-magic-sparkles"></i>
      {{ strings.compatibilityHint }}
    </p>
    {{/if}}

    {{#if conditionInvalid}}
    <p class="notification warning sc-cae-validation-warning">
      <i class="fas fa-triangle-exclamation"></i>
      {{ strings.invalid }} {{ validationMessage }}
    </p>
    {{/if}}

    <details class="sc-cae-evaluation sc-cae-evaluation--{{ evaluation.state }}">
      <summary class="sc-cae-evaluation__header">{{ strings.evaluationHeading }}</summary>
      <div class="sc-cae-evaluation__body">
      <p class="hint sc-cae-evaluation__message">
        {{#if evaluation.isEmpty}}
        {{ strings.evaluationEmpty }}
        {{else}}
          {{#if evaluation.isTrue}}
          {{ strings.evaluationTrue }}
          {{else}}
            {{#if evaluation.isFalse}}
            {{ strings.evaluationFalse }}
            {{else}}
            {{ strings.evaluationError }} {{ evaluation.errorMessage }}
            {{/if}}
          {{/if}}
        {{/if}}
      </p>
      {{#if evaluation.hasResult}}
      <p class="hint sc-cae-evaluation__detail">
        <strong>{{ strings.evaluationResult }}:</strong>
        <code>{{ evaluation.resultLabel }}</code>
      </p>
      {{/if}}
      {{#if evaluation.contextLabel}}
      <p class="hint sc-cae-evaluation__detail">
        <strong>{{ strings.evaluationContext }}:</strong>
        {{ evaluation.contextLabel }}
      </p>
      {{/if}}
      {{#if evaluation.effectStateLabel}}
      <p class="hint sc-cae-evaluation__detail">
        <strong>{{ strings.evaluationEffectState }}:</strong>
        <code>{{ evaluation.effectStateLabel }}</code>
      </p>
      {{/if}}
      </div>
    </details>

    <div class="form-group sc-cae-badge-label-group">
      <label>{{ strings.badgeLabel }}</label>
      <div class="form-fields">
        {{#if editable}}
        <input
          type="text"
          name="{{ conditionBadgeLabelFlagPath }}"
          value="{{ conditionBadgeLabel }}"
          maxlength="{{ badgeLabelMaxLength }}"
          placeholder="{{ strings.badgeLabelPlaceholder }}"
          class="sc-cae-badge-label-input"
        />
        {{else}}
        <input
          type="text"
          value="{{ conditionBadgeLabel }}"
          class="sc-cae-badge-label-input"
          disabled
        />
        {{/if}}
        <span class="sc-cae-badge-label-counter">{{ conditionBadgeLabelLength }}/{{ badgeLabelMaxLength }}</span>
      </div>
      <p class="hint">{{ strings.badgeLabelHint }}</p>
    </div>

    <div class="form-group">
      <label>{{ strings.applyBehavior }}</label>
      <div class="form-fields">
        {{#if editable}}
        <select name="{{ applyBehaviorFlagPath }}">
          <option value="auto" {{#if applyBehaviorIsDefault}}selected{{/if}}>{{ strings.applyBehaviorUpdate }}</option>
          <option value="duplicate" {{#if applyBehaviorIsDuplicate}}selected{{/if}}>{{ strings.applyBehaviorDuplicate }}</option>
          {{#if showDaeApplyBehavior}}
          <option value="dae" {{#if applyBehaviorIsDae}}selected{{/if}}>{{ strings.applyBehaviorDae }}</option>
          {{/if}}
        </select>
        {{else}}
        <input
          type="text"
          value="{{ applyBehavior }}"
          disabled
        />
        {{/if}}
      </div>
      <p class="hint" data-sc-cae-apply-behavior-hint>{{ applyBehaviorDescription }}</p>
    </div>

    <div class="sc-cae-code-header">
      <div class="sc-cae-code-header-title">
        <span>{{ strings.label }}</span>
        <i
          class="fa-solid fa-circle-info sc-cae-code-help-icon"
          data-tooltip="{{ codeHelpTooltip }}"
          data-tooltip-direction="UP"
          aria-label="{{ strings.helpTooltipLabel }}"
        ></i>
      </div>
      <a class="sc-cae-help-link" href="{{ conditionWikiUrl }}" target="_blank" rel="noopener">
        <i class="fas fa-up-right-from-square"></i> {{ strings.wiki }}
      </a>
    </div>

    {{#if editable}}
    <code-mirror
      name="{{ conditionFlagPath }}"
      language="javascript"
      indent="2"
      class="sc-cae-condition-code"
      aria-label="{{ strings.label }}"
    >{{ conditionInputValue }}</code-mirror>
    {{else}}
    <textarea
      name="{{ conditionFlagPath }}"
      class="sc-cae-condition-code sc-cae-condition-code--readonly"
      rows="10"
      placeholder="{{ strings.placeholder }}"
      disabled>{{ conditionInputValue }}</textarea>
    {{/if}}
  </fieldset>
</section>
